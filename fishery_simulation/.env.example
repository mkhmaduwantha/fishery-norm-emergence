# Anthropic (optional — only needed with --provider anthropic)
ANTHROPIC_API_KEY=your_key_here

# OpenAI (optional — only needed with --provider openai)
OPENAI_API_KEY=your_key_here

# Ollama runs locally — no API key needed.
# Pull the model first: ollama pull gpt-oss:20b
# Then run: python run.py --provider ollama --model gpt-oss:20b ...
